{
  "manifest_version": 3,
  "name": "Pinned Tab Sync",
  "version": "1.1.0",
  "description": "Syncs pinned tabs and tab groups (including collapsed state) across devices via chrome.storage.sync.",
  "permissions": ["tabs", "tabGroups", "storage", "favicon"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pinned Tab Sync"
  },
  "web_accessible_resources": [
    {
      "resources": ["/_favicon/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
